  "keyFeatures": [
    "Multi-blockchain stablecoin payments (Stellar, EVM chains, Solana)",
    "Global payment rails (PIX, ACH, Wire, SPEI, SWIFT, etc.)",
    "KYC/KYB receiver management with document verification",
    "Real-time quotes and FX rates",
    "Virtual accounts for fiat on-ramp",
    "Webhook event notifications with signature verification",
    "TypeScript-first with full type safety",
    "Consistent error handling pattern"
  ],
